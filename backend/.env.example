# =============================================================================
# BoneGuard Backend — Environment Variables
# Copy this file to .env and fill in your real values
# NEVER commit .env — only commit this .env.example file
# =============================================================================

# HuggingFace Space URL (your Python AI inference server)
HF_API_URL=https://tihumkabir-boneguard-api.hf.space

# Port this Node.js server runs on
PORT=3001

# Timeout for HuggingFace requests (ms) — HF free tier sleeps
HF_TIMEOUT_MS=60000

# Gemini API key — used for RAG embeddings only
# Get free at: aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here

# Groq API key — used for Bonne chatbot generation
# Get free at: console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Path to vector store JSON (relative to backend folder)
VECTORSTORE_PATH=../bonne-chatbot/data/vectorstore.json

# Frontend URL (for CORS) — update when deploying
FRONTEND_URL=http://localhost:3000
